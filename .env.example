# Fruger — SQLite database (rides, users, bids, driver locations, optional NYC pickups).
# Default: fruger.db in the project root. Use an absolute path in production.
# DATABASE_PATH=

# JWT signing (required in production)
JWT_SECRET_KEY=change-me

# Session lifetime for httpOnly cookie login (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional first admin created on startup if no user with this email exists
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Default users if missing (fresh DB). Change in production.
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=Adminpass123
DEFAULT_RIDER_EMAIL=rider@local.dev
DEFAULT_RIDER_PASSWORD=Riderpass123
DEFAULT_DRIVER_EMAIL=driver@local.dev
DEFAULT_DRIVER_PASSWORD=Driverpass123

# Show default credentials on /login (false in production)
SHOW_DEFAULT_ACCOUNT_HINTS=true

# Driver hub: allow "Seed demo data" button (POST /api/v1/driver/seed-demo). Set false in production.
DRIVER_DEMO_SEED=true

# Google Maps JavaScript API key (embeds: driver / rider bids / admin fleet — restrict by HTTP referrer).
# In Google Cloud: enable "Maps JavaScript API" and "Places API" for rider hub address search (otherwise Autocomplete may fail).
# Loaded from `.env` or `root.env` in the project root (see app.config._load_dotenv_files).
GOOGLE_MAPS_API_KEY=

# Tests / CI: skip downloading NYC TLC pickup CSV into SQLite (operational migrations still run).
# Set to 1, true, or yes to enable.
SKIP_DATASET_SEED=

# On startup, if the rides table is empty, seed demo riders/drivers/locations/bids/rides (set false in production).
# Demo accounts use password FrugerDemo2024! (see startup logs for emails).
AUTO_OPERATIONAL_DEMO_SEED=true
